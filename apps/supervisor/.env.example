# --- @remote-dev/supervisor environment ---
# Copy to .env.local for local development.

# Next.js UI + REST API port (dev:supervisor runs on this).
PORT=6003

# Where the Supervisor stores its own SQLite database.
# Empty -> ~/.remote-dev-supervisor (default). Set to ./.data for a repo-local DB.
SUPERVISOR_DATA_DIR=

# First admin user. On startup the auth layer seeds a supervisor_user row with
# role=admin for this email if none exists. In local dev (no CF Access), this
# email is also the authenticated identity.
SUPERVISOR_ADMIN_EMAIL=

# Cloudflare Access for the Supervisor's OWN application (distinct AUD from any
# instance). One of CF Access OR native OIDC (below) is required in production;
# leave blank for local dev (auth falls back to SUPERVISOR_ADMIN_EMAIL).
SUPERVISOR_CF_ACCESS_TEAM=
SUPERVISOR_CF_ACCESS_AUD=

# --- Native OIDC login (OPTIONAL; alternative/addition to CF Access) ---
# Generic OIDC via NextAuth. When issuer + client id + client secret + AUTH_SECRET
# are ALL set, the Supervisor exposes a /login page with a "Sign in with
# <SUPERVISOR_OIDC_NAME>" button. Dual-auth: a request authenticates with a valid
# CF Access JWT OR a valid OIDC session. CLOSED ALLOWLIST: an OIDC login is only
# accepted if the email already exists as a supervisor_user OR equals
# SUPERVISOR_ADMIN_EMAIL — unknown emails the IdP authenticates are denied.
# Callback URL to register with the IdP: https://<host>/api/auth/callback/oidc
SUPERVISOR_OIDC_ISSUER=
SUPERVISOR_OIDC_CLIENT_ID=
SUPERVISOR_OIDC_CLIENT_SECRET=
# Display label for the sign-in button (e.g. "Authentik", "Okta"). Default: "SSO".
SUPERVISOR_OIDC_NAME=

# Secret NextAuth uses to sign the JWT session cookie. REQUIRED when OIDC is used.
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Escape hatch: when "1", bypasses the production requirement that CF Access OR
# OIDC be configured (otherwise the server refuses to start in prod, and the auth
# layer refuses the SUPERVISOR_ADMIN_EMAIL fallback). FOR EXPLICIT TESTING ONLY —
# never set in a real production deployment.
SUPERVISOR_ALLOW_INSECURE_AUTH=

# Shared secret the Supervisor router presents (header
# x-supervisor-internal-secret) to read the ready-instance allowlist at
# GET /api/internal/routes. Required in production; if unset there, that
# endpoint returns 503. In dev it may be left blank (endpoint is open).
SUPERVISOR_INTERNAL_SECRET=

# Kubeconfig for local development against a k3d/kind cluster. Optional —
# the k8s client uses loadFromDefault() which already honours KUBECONFIG and
# the in-cluster ServiceAccount token in production.
KUBECONFIG=

# --- Provisioning (read by the controller/reconciler) ---

# External host instances are served under. Each instance gets
# AUTH_URL=https://<host>/<slug> and baseUrl set from this. Required to provision.
SUPERVISOR_INSTANCE_HOST=

# The slug-aware GHCR image:sha the instance StatefulSet runs. Required to provision.
SUPERVISOR_INSTANCE_IMAGE=

# Default PVC StorageClass for new instances. Empty -> the cluster's default
# StorageClass. jvcx.5 adds live discovery + a per-instance dropdown.
SUPERVISOR_DEFAULT_STORAGE_CLASS=

# Default PVC size for new instances.
SUPERVISOR_DEFAULT_STORAGE_SIZE=10Gi

# Cloudflare Access tags injected into every instance's `rdv-shared` Secret (the
# INSTANCES' Access app — distinct from the Supervisor's own SUPERVISOR_CF_ACCESS_*).
# REQUIRED in production: the reconciler refuses to provision an instance without
# them (an instance with empty CF tags can't enforce CF Access). In dev they may
# be blank, but provisioned instances will then lack CF Access.
CF_ACCESS_TEAM=
CF_ACCESS_AUD=

# Optional GitHub OAuth creds injected into each instance's `rdv-<slug>` Secret.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: PRIVATE instance-image pull credential (remote-dev-2xhg). When set,
# the provisioner references this Secret name in each instance pod's
# imagePullSecrets; when the dockerconfigjson below is ALSO set, it CREATES that
# dockerconfigjson Secret in the instance namespace. All optional — unset means a
# public registry (no pull secret).
SUPERVISOR_INSTANCE_IMAGE_PULL_SECRET_NAME=
# The raw .dockerconfigjson value ({"auths":{...}}). THIS IS A SECRET — never
# log/echo it. Requires SUPERVISOR_INSTANCE_IMAGE_PULL_SECRET_NAME to be set.
SUPERVISOR_INSTANCE_IMAGE_PULL_DOCKERCONFIGJSON=

# Optional: pin instance pods to compatible nodes on a mixed-arch cluster
# (remote-dev-389c). Comma-separated key=value pairs, e.g.
# `kubernetes.io/arch=amd64` or `kubernetes.io/arch=amd64,disktype=ssd`.
# Unset -> no pinning (any node / any arch).
SUPERVISOR_INSTANCE_NODE_SELECTOR=

# Minimum log level: error | warn | info | debug | trace
LOG_LEVEL=info
