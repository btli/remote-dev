{
  "name": "@remote-dev/supervisor",
  "version": "0.1.0",
  "description": "k3s Supervisor control-plane service for Remote Dev — provisions and lifecycle-manages instances on a Kubernetes cluster",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env.local -- sh -c 'next dev -p ${PORT:-6003}'",
    "build": "next build",
    "start": "dotenv -e .env.local -- sh -c 'next start -p ${PORT:-6003}'",
    "start:standalone": "node .next/standalone/apps/supervisor/server.js",
    "dev:controller": "dotenv -e .env.local -- tsx src/controller/index.ts",
    "controller": "bun src/controller/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:codegen": "bun run scripts/codegen-schema.ts",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@kubernetes/client-node": "^1.4.0",
    "@libsql/client": "^0.15.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.1.3",
    "lucide-react": "^0.562.0",
    "next": "16.1.0",
    "next-auth": "^5.0.0-beta.30",
    "pg": "8.21.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9",
    "eslint-config-next": "16.1.0",
    "happy-dom": "^20.0.11",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.16"
  }
}
