<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Required by local_auth / BiometricPrompt on Android 9+. -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC"/>
    <!-- Required for FCM push notification token registration / API calls. -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- image_picker (gallery) on API 33+ uses scoped media permissions. -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <!-- Legacy gallery access for API <= 32. maxSdkVersion mirrors
         image_picker's docs so newer devices skip this permission. -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>
    <!-- Camera capture via image_picker (long-press shortcut on the
         smart-key strip's image button) + WebView getUserMedia for
         in-terminal image capture (bd remote-dev-cp47). -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <!-- Declare CAMERA feature usage as optional so Play store filtering
         doesn't hide the app from camera-less devices. -->
    <uses-feature android:name="android.hardware.camera" android:required="false"/>
    <application
        android:label="RemoteDev"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- App Links: https://dev.bryanli.net/m/* (P4.6) -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https"
                      android:host="dev.bryanli.net"
                      android:pathPrefix="/m/" />
            </intent-filter>
            <!-- Custom scheme: remotedev://... (P4.7) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="remotedev" />
            </intent-filter>
        </activity>
        <!-- FCM: default notification icon (monochrome silhouette for status bar) -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_notification" />
        <!-- FCM: notification accent color (Tokyo Night blue) -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/notification_accent" />
        <!-- FCM: default notification channel id — MUST match server's
             FcmPushGateway channel id (`rdv_notifications`). -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="rdv_notifications" />
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
