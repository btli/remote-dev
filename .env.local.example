# Generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here

# Optional: Generic OIDC SSO (see docs/SETUP.md → "OIDC Single Sign-On").
# The provider + login button appear only when issuer + client id + secret are
# all set. Sign-in is default-denied unless the email is in authorizedUsers.
# Callback (redirect) URL to register at your IdP: https://<host>/api/auth/callback/oidc
# OIDC_ISSUER=https://idp.example.com
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_NAME=OIDC
# NEXT_PUBLIC_OIDC_NAME=OIDC
