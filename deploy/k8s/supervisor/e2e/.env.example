# --- Supervisor-router E2E smoke knobs ---
# Copy to .env (gitignored) to override defaults for a local run. run.sh exports
# sane defaults for all of these, so a plain `./run.sh` needs no .env.

# Instance slugs to provision + assert (comma-separated).
E2E_SLUGS=alpha,beta

# Host port the router publishes on (the smoke's single entrypoint).
ROUTER_HOST_PORT=6004

# Shared instance AUTH_SECRET — both instances boot with this; the smoke mints
# the terminal WS token (HMAC over the same secret). TEST-ONLY value.
E2E_INSTANCE_AUTH_SECRET=rdv-e2e-smoke-shared-auth-secret-000000000000

# Router <-> Supervisor allowlist shared secret (x-supervisor-internal-secret).
SUPERVISOR_INTERNAL_SECRET=rdv-e2e-internal-secret

# Seeded instance owner (also the Supervisor admin in insecure-auth mode).
SUPERVISOR_ADMIN_EMAIL=smoke@example.com

# Instance image Node base (the Dockerfile default — Node 24 + Debian trixie's
# glibc 2.41, which the image's `rdv --version` gate requires; bare `24` fails it).
NODE_VERSION=24-trixie-slim

# Image tags (override to reuse pre-built images, e.g. in CI).
INSTANCE_IMAGE=rdv-instance:e2e
SUPERVISOR_IMAGE=rdv-supervisor:e2e
ROUTER_IMAGE=rdv-router:e2e
